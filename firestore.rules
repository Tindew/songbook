rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || (
            request.auth.token.email != null
            && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
          )
        );
    }

    function validSong(data) {
      return data.keys().hasAll(['title', 'artist', 'tags', 'genres', 'status', 'requestCommand', 'isHidden'])
        && data.title is string
        && data.artist is string
        && data.tags is list
        && data.genres is list
        && data.status in ['available', 'practice', 'condition', 'blocked', 'special']
        && data.requestCommand is string
        && data.isHidden is bool;
    }

    function validSongRequest(data) {
      return data.keys().hasAll(['title', 'artist', 'status', 'createdAt'])
        && data.title is string
        && data.artist is string
        && data.status in ['pending', 'approved', 'rejected'];
    }

    function likeCountUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'updatedAt'])
        && request.resource.data.likeCount is number
        && request.resource.data.likeCount >= 0
        && (
          request.resource.data.likeCount == resource.data.likeCount + 1
          || request.resource.data.likeCount == resource.data.likeCount - 1
        );
    }

    function validSiteSettings(data) {
      return data.keys().hasAll(['siteTitle', 'heroTitle', 'heroSubtitle', 'requestEnabled', 'copyCommandEnabled'])
        && data.siteTitle is string
        && data.heroTitle is string
        && data.heroSubtitle is string
        && data.requestEnabled is bool
        && data.copyCommandEnabled is bool;
    }

    match /songs/{songId} {
      allow read: if true;
      allow create: if isAdmin() && validSong(request.resource.data);
      // 관리자는 전체 수정, 로그인 유저는 좋아요 수만 ±1 변경 가능.
      allow update: if (isAdmin() && validSong(request.resource.data)) || likeCountUpdate();
      allow delete: if isAdmin();
    }

    match /userLikes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /songRequests/{requestId} {
      allow create: if validSongRequest(request.resource.data) && request.resource.data.status == 'pending';
      allow read, update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isAdmin()
        || (isSignedIn() && (request.auth.uid == uid || request.auth.token.email == uid));
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin() && validSiteSettings(request.resource.data);
    }
  }
}
